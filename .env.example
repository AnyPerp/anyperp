# AnyPerp local/testnet configuration. Copy to .env and fill blank values.
# Never commit .env. Never reuse the previously shared test key/address; it is compromised.
# Multi-env: configs/testnet.json | mainnet.json | anvil.json — see docs/TESTNET_LAUNCH.md
# Commands: pnpm launch:check | pnpm launch --env testnet --write-host-env

# Network and public URLs
ANYPERP_ENV=testnet
NETWORK_MODE=testnet
CHAIN_ID=46630
RPC_HTTP_URL=https://rpc.testnet.chain.robinhood.com
RPC_HTTP_URLS=https://rpc.testnet.chain.robinhood.com
RPC_WS_URLS=wss://feed.testnet.chain.robinhood.com
START_BLOCK=0
NEXT_PUBLIC_NETWORK_MODE=testnet
NEXT_PUBLIC_CHAIN_ID=46630
NEXT_PUBLIC_CHAIN_NAME=RHC Testnet
NEXT_PUBLIC_RPC_URL=https://rpc.testnet.chain.robinhood.com
NEXT_PUBLIC_EXPLORER_URL=https://explorer.testnet.chain.robinhood.com
NEXT_PUBLIC_ALLOW_MOCK_ORACLE=true
NEXT_PUBLIC_ALLOW_MINTABLE_COLLATERAL=true
NEXT_PUBLIC_PUBLIC_FAUCET=true
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DOCS_URL=http://localhost:3000/?surface=docs
NEXT_PUBLIC_APP_URL=http://localhost:3000/?surface=app

# Local services
PORT=4000
HOST=127.0.0.1
DATABASE_URL=postgresql://anyperp:anyperp@localhost:5432/anyperp
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info

# Fresh deployment addresses. Leave blank until scripts/deploy-testnet.mjs succeeds.
MARKET_FACTORY_ADDRESS=
MARKET_REGISTRY_ADDRESS=
ORACLE_ROUTER_ADDRESS=
LIQUIDATION_ENGINE_ADDRESS=
TRIGGER_ORDER_MANAGER_ADDRESS=
PROTOCOL_BACKSTOP_ADDRESS=
INDEXED_CONTRACT_ADDRESSES=
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=
NEXT_PUBLIC_MARKET_REGISTRY_ADDRESS=
NEXT_PUBLIC_ORACLE_ROUTER_ADDRESS=
NEXT_PUBLIC_LIQUIDATION_ENGINE_ADDRESS=
NEXT_PUBLIC_TRIGGER_ORDER_MANAGER_ADDRESS=
NEXT_PUBLIC_COLLATERAL_ADDRESS=

# Testnet deployment roles. These must be fresh, independently controlled values.
# GOVERNANCE_TIMELOCK_ADDRESS must be a deployed timelock contract and must not be
# the deployer EOA. Treasury/council should be fresh testnet multisig addresses.
DEPLOYER_PRIVATE_KEY=
GOVERNANCE_TIMELOCK_ADDRESS=
GOVERNANCE_PROPOSER_ADDRESS=
GOVERNANCE_EXECUTOR_ADDRESS=
TIMELOCK_ADMIN_ADDRESS=0x0000000000000000000000000000000000000000
GOVERNANCE_TIMELOCK_DELAY_SECONDS=86400
EMERGENCY_COUNCIL_ADDRESS=
PROTOCOL_TREASURY_ADDRESS=
DEPLOY_MOCK_COLLATERAL=true

# Mainnet-only gates (leave unset on testnet)
# MAINNET_READY=true
# AUDIT_ATTESTATION=ipfs://... or https://...

# Optional seed EOAs for liquidation probes (demo traders). Merged with on-chain
# discovery from recent TradeExecuted + MarginDeposited logs (lookback window).
# KEEPER_WATCH_ACCOUNTS=0x...,0x...
# KEEPER_TRADE_LOOKBACK_BLOCKS=8000
# KEEPER_TRIGGER_LOOKBACK=200
# KEEPER_WITHDRAWAL_LOOKBACK=100
# KEEPER_LOG_CHUNK_BLOCKS=2000

# Keeper signer. Use a separate, low-balance testnet key; never the deployer key.
KEEPER_PRIVATE_KEY=

# API rate limit (single-process testnet)
# API_RATE_LIMIT_MAX=120
# API_RATE_LIMIT_WINDOW_MS=60000

# After Postgres is up: pnpm db:migrate  (001 + 002 projections)
# Host runbook: ops/TESTNET_HOST.md

# Production-oracle admission inputs are intentionally blank. Configure only after
# bytecode, denomination, heartbeat, sequencer feed, DEX pool, depth and history are
# independently verified. Mock adapters are local-test only.
CHAINLINK_SEQUENCER_UPTIME_FEED=
CHAINLINK_BASE_USD_FEED=
CHAINLINK_BASE_USD_DESCRIPTION_HASH=
CHAINLINK_BASE_USD_HEARTBEAT_SECONDS=
DEX_TWAP_POOL_ADDRESS=
DEX_TWAP_QUOTE_TOKEN=
DEX_TWAP_WINDOW_SECONDS=

# Market data — DexScreener (MC/vol UI) + Pyth Hermes (index reference)
DEXSCREENER_BASE_URL=https://api.dexscreener.com
DEXSCREENER_CACHE_TTL_MS=30000
DEXSCREENER_DEFAULT_CHAIN=robinhood
PYTH_HERMES_URL=https://hermes.pyth.network
# Optional; public Hermes works without a key. Never commit real secrets.
PYTH_API_KEY=
# Presets and/or 64-char hex feed ids: BTC,ETH,SOL
PYTH_DEFAULT_FEED_IDS=BTC,ETH,SOL
PYTH_MAX_PRICE_AGE_SECONDS=120
PYTH_CACHE_TTL_MS=5000

# Pyth → MockOracle push (testnet settlement bridge)
# ORACLE_ADAPTERS=0x...  # defaults from deployments/pending-e2e-config.json
# ORACLE_BASE_TOKEN=0x...
ORACLE_PYTH_SYMBOL=BTC
ORACLE_PUSH_INTERVAL_MS=30000
# ORACLE_PUSHER_PRIVATE_KEY=  # else DEPLOYER_PRIVATE_KEY
# pnpm oracle:push | pnpm oracle:push:loop

# Optional operations integrations
ALERT_WEBHOOK_URL=
SENTRY_DSN=
