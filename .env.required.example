# VALUES REQUIRED FROM THE PROJECT OWNER
# Copy the needed lines into .env. Do not send private keys in chat or commit them.

# 1) Fresh testnet deployer funded with Robinhood Chain testnet ETH.
DEPLOYER_PRIVATE_KEY=

# 2) Fresh governance proposer/executor multisigs. Run
# `pnpm deploy:governance:testnet`, then copy its output into
# GOVERNANCE_TIMELOCK_ADDRESS. Leave TIMELOCK_ADMIN_ADDRESS at zero unless a
# temporary bootstrap admin is explicitly reviewed.
GOVERNANCE_PROPOSER_ADDRESS=
GOVERNANCE_EXECUTOR_ADDRESS=
TIMELOCK_ADMIN_ADDRESS=0x0000000000000000000000000000000000000000
GOVERNANCE_TIMELOCK_DELAY_SECONDS=86400
GOVERNANCE_TIMELOCK_ADDRESS=

# 3) Separate emergency council and protocol treasury testnet multisigs.
EMERGENCY_COUNCIL_ADDRESS=
PROTOCOL_TREASURY_ADDRESS=

# 4) Separate low-balance keeper signer.
KEEPER_PRIVATE_KEY=

# 5) Confirmed testnet collateral decision. Keep false to use an existing verified
# allowlisted collateral; set true only for a mock-collateral test deployment.
DEPLOY_MOCK_COLLATERAL=false

# 6) Oracle route evidence for every token intended to activate. These are not
# optional for a real market: verified contract/feed, denomination, heartbeat,
# sequencer feed, independent DEX TWAP pool, quote token, depth, and observation history.
CHAINLINK_SEQUENCER_UPTIME_FEED=
CHAINLINK_BASE_USD_FEED=
CHAINLINK_BASE_USD_DESCRIPTION_HASH=
CHAINLINK_BASE_USD_HEARTBEAT_SECONDS=
DEX_TWAP_POOL_ADDRESS=
DEX_TWAP_QUOTE_TOKEN=
DEX_TWAP_WINDOW_SECONDS=

# 7) DNS/hosting values when the three public surfaces are ready.
NEXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN
NEXT_PUBLIC_DOCS_URL=https://docs.YOUR_DOMAIN
NEXT_PUBLIC_APP_URL=https://app.YOUR_DOMAIN

# Filled from a NEW successful deployment manifest, not manually guessed.
MARKET_FACTORY_ADDRESS=
MARKET_REGISTRY_ADDRESS=
ORACLE_ROUTER_ADDRESS=
LIQUIDATION_ENGINE_ADDRESS=
TRIGGER_ORDER_MANAGER_ADDRESS=
PROTOCOL_BACKSTOP_ADDRESS=
INDEXED_CONTRACT_ADDRESSES=
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=
NEXT_PUBLIC_MARKET_REGISTRY_ADDRESS=
NEXT_PUBLIC_ORACLE_ROUTER_ADDRESS=
NEXT_PUBLIC_LIQUIDATION_ENGINE_ADDRESS=
NEXT_PUBLIC_TRIGGER_ORDER_MANAGER_ADDRESS=
NEXT_PUBLIC_COLLATERAL_ADDRESS=
