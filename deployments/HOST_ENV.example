# Server-only (API / indexer / keepers — never NEXT_PUBLIC_):
# DATABASE_URL=...
# REDIS_URL=...
# KEEPER_PRIVATE_KEY=...   # NOT deployer; low-balance test ETH only
# MARKET_FACTORY_ADDRESS=0xd1e154498a382074cf66f3274244d55b80b1a52d
# MARKET_REGISTRY_ADDRESS=0xbdd1ab0bf5ea2846e05d80771958332f328e6da3
# ORACLE_ROUTER_ADDRESS=0xd9e74c0ebdfbb9538b63fe5d7e4456456ef4a13b
# LIQUIDATION_ENGINE_ADDRESS=0x381c70f1eead30094543e544fab0bae3d412f212
# TRIGGER_ORDER_MANAGER_ADDRESS=0x6ca42a07fb4bf7ff5125a971a188a47670ed4b45
# INDEXED_CONTRACT_ADDRESSES=<factory>,<registry>,<oracle>
# CORS_ORIGINS=https://anyperp.fun,http://localhost:3000
# HOST=0.0.0.0
# PORT=4000
# Apply DB: node scripts/migrate-all.mjs  (001 + 002 projections)
# DexScreener + Pyth (API host)
# DEXSCREENER_BASE_URL=https://api.dexscreener.com
# DEXSCREENER_DEFAULT_CHAIN=robinhood
# PYTH_HERMES_URL=https://hermes.pyth.network
# PYTH_API_KEY=
# PYTH_DEFAULT_FEED_IDS=BTC,ETH,SOL
# NEXT_PUBLIC_API_URL=https://anyperp-stack-production.up.railway.app
# NEXT_PUBLIC_WS_URL=wss://anyperp-stack-production.up.railway.app/ws
#
# Railway project: anyperp (anyperp-stack = API+indexer+keepers, Redis service)
# Neon DATABASE_URL for projections; see ops/TESTNET_HOST.md
#
# GMGN (swap/route API only — header x-route-key). Not used for OHLCV charts.
# Docs: https://docs.gmgn.ai — charts use DexScreener mainnet price/MC windows.
# GMGN_ROUTE_KEY=
# GMGN_API_KEY=
