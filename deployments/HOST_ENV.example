# Copy these into your production/hosting env (Cloudflare / Vercel / etc.)
# Generate a fresh template: pnpm launch --env testnet --write-host-env
# After execute-e2e finishes, also add DEMO_* from deployments/live-demo-market.json
# Mainnet later: same keys, configs/mainnet.json + faucet/mock flags false.

ANYPERP_ENV=testnet
NETWORK_MODE=testnet
CHAIN_ID=46630

NEXT_PUBLIC_NETWORK_MODE=testnet
NEXT_PUBLIC_CHAIN_ID=46630
NEXT_PUBLIC_CHAIN_NAME=RHC Testnet
NEXT_PUBLIC_RPC_URL=https://rpc.testnet.chain.robinhood.com
