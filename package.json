{
  "name": "anyperp",
  "version": "0.1.0-testnet",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "description": "AnyPerp — any token, a perp, today. Isolated permissionless markets on Robinhood Chain (anyperp.fun)",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "api:dev": "tsx services/api/src/server.ts",
    "indexer:dev": "tsx services/indexer/src/indexer.ts",
    "keepers:dev": "tsx services/keepers/src/worker.ts",
    "infra:up": "docker compose up -d postgres redis prometheus",
    "infra:down": "docker compose down",
    "contracts:compile": "node scripts/compile-contracts.mjs",
    "deploy:governance:testnet": "node scripts/deploy-governance-testnet.mjs",
    "deploy:protocol:testnet": "node scripts/deploy-testnet.mjs",
    "launch": "node scripts/launch.mjs",
    "launch:check": "node scripts/check-launch-ready.mjs --env testnet",
    "launch:testnet": "node scripts/launch.mjs --env testnet",
    "launch:mainnet": "node scripts/launch.mjs --env mainnet --require-gates",
    "oracle:push": "node scripts/pyth-push-oracle.mjs",
    "oracle:push:loop": "node scripts/pyth-push-oracle.mjs --loop",
    "markets:launch-listed": "node scripts/launch-listed-assets.mjs",
    "test:unit": "vitest run",
    "test:python": "python -m pytest simulations/tests",
    "test": "pnpm contracts:compile && pnpm test:unit && pnpm build && node --test tests/rendered-html.test.mjs",
    "smoke:contracts": "node scripts/smoke-contracts-local.mjs",
    "smoke:adversarial": "node scripts/smoke-adversarial-solvency.mjs",
    "smoke:services": "node scripts/smoke-services.mjs",
    "smoke:all": "pnpm smoke:contracts && pnpm smoke:services",
    "verify": "node scripts/verify-project.mjs",
    "verify:brand": "node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern contracts/out",
    "db:check": "node scripts/check-migration.mjs",
    "db:migrate": "node scripts/migrate-all.mjs"
  },
  "dependencies": {
    "@fastify/cors": "11.1.0",
    "@fastify/websocket": "11.2.0",
    "@openzeppelin/contracts": "5.4.0",
    "@tanstack/react-query": "5.90.5",
    "bullmq": "5.61.2",
    "dotenv": "17.2.3",
    "fastify": "5.6.1",
    "ioredis": "5.8.1",
    "lightweight-charts": "^5.2.0",
    "next": "16.2.6",
    "pg": "8.16.3",
    "pino": "9.14.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "viem": "2.38.5",
    "wagmi": "2.19.5",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/pg": "8.15.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "ganache": "7.9.2",
    "react-server-dom-webpack": "19.2.6",
    "solc": "0.8.30",
    "tailwindcss": "4.2.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "3.2.4",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
